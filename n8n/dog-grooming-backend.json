      "id": "wf04-no-pdf-gate",
      "name": "IF: PRF text but no PDF stashed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1340, 920]
    },
    {
      "parameters": {
        "chatId": "={{ $json.chat_id }}",
        "text": "=⚠️ I see the profile_id {{ $json.profile_id }} but I don't have a pending PDF for this chat. Send the PDF first, then send the profile_id as a follow-up message.",
        "additionalFields": {
          "reply_to_message_id": "={{ $json.message_id }}"
        }
      },
      "id": "wf04-no-pdf-reply",
