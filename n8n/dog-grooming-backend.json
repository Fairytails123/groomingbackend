      "id": "wf04-route",
      "name": "IF: PDF document?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [680, 700]
    },

    {
      "parameters": {
        "jsCode": "// PDF branch — stash the file_id under chat_id in workflow static data so\n// a follow-up text message can pick it up. Last-wins per chat (single-user\n// pattern). Static data persists across executions.\n\nconst msg = $json.message ?? {};\nconst chatId = String(msg.chat?.id ?? '');\nconst pendingByChat = $getWorkflowStaticData('global').pendingPdfs ?? {};\npendingByChat[chatId] = {\n  file_id: msg.document?.file_id,\n  file_name: msg.document?.file_name ?? 'telegram.pdf',\n  message_id: msg.message_id,\n  user_first_name: msg.from?.first_name ?? '',\n  received_at: new Date().toISOString(),\n};\n$getWorkflowStaticData('global').pendingPdfs = pendingByChat;\n\nreturn [{\n  json: {\n    chat_id: msg.chat?.id,\n    message_id: msg.message_id,\n    file_name: msg.document?.file_name ?? 'telegram.pdf',\n    user_first_name: msg.from?.first_name ?? '',\n  },\n}];\n"
      },
      "id": "wf04-stash",
      "name": "Stash pending PDF",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 600]
    },
    {
      "parameters": {
        "chatId": "={{ $json.chat_id }}",
        "text": "=✓ Got the PDF \"{{ $json.file_name }}\".\n\nNow reply with the profile_id to attach it to, like:\n\nPRF-001\n\n(Look up the profile_id at https://fairytails123.github.io/groomingbackend/admin/library.html if you don't know it.)",
        "additionalFields": {
          "reply_to_message_id": "={{ $json.message_id }}"
        }
      },
      "id": "wf04-stash-reply",
      "name": "Telegram: PDF received reply",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1120, 600],
      "credentials": {
        "telegramApi": { "name": "Telegram groomingbackend" }
      }
    },

    {
      "parameters": {
        "jsCode": "// Text branch — parse PRF-XXX from the message text or caption,\n// look up the stashed PDF for this chat. Three outcomes:\n//   1. Text has PRF-XXX AND we have a stashed PDF → set has_pending = true\n//      and surface file_id, profile_id for the upload chain.\n//   2. Text has PRF-XXX BUT no stashed PDF → has_pending = false, error_kind = 'no_pdf'.\n//   3. Text has no PRF-XXX → has_pending = false, error_kind = 'no_match' (workflow ignores).\n\nconst msg = $json.message ?? {};\nconst chatId = String(msg.chat?.id ?? '');\nconst text = String(msg.text ?? msg.caption ?? '').trim();\nconst profileMatch = text.match(/\\bPRF-\\d{3,}\\b/i);\nconst profileId = profileMatch ? profileMatch[0].toUpperCase() : null;\n\nconst static_ = $getWorkflowStaticData('global');\nconst pendingByChat = static_.pendingPdfs ?? {};\nconst pending = pendingByChat[chatId] ?? null;\n\nlet errorKind = null;\nlet hasPending = false;\nif (!profileId) {\n  errorKind = 'no_match';\n} else if (!pending) {\n  errorKind = 'no_pdf';\n} else {\n  hasPending = true;\n}\n\nreturn [{\n  json: {\n    chat_id: msg.chat?.id,\n    message_id: msg.message_id,\n    text,\n    profile_id: profileId,\n    file_id: pending?.file_id ?? null,\n    file_name: pending?.file_name ?? null,\n    user_first_name: msg.from?.first_name ?? '',\n    has_pending: hasPending,\n    error_kind: errorKind,\n  },\n}];\n"
      },
      "id": "wf04-text-parse",
      "name": "Parse text + look up pending",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 800]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "id": "has-pending",
              "leftValue": "={{ $json.has_pending }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "wf04-have-pending-gate",
      "name": "IF: have pending PDF + PRF?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1120, 800]
    },

    {
      "parameters": {
        "resource": "file",
        "fileId": "={{ $json.file_id }}"
      },
      "id": "wf04-getfile",
      "name": "Telegram getFile",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1340, 760],
      "credentials": {
        "telegramApi": { "name": "Telegram groomingbackend" }
