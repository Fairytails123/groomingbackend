    {
      "parameters": {
        "method": "POST",
        "url": "https://script.google.com/macros/s/AKfycby5CU8J-xyCn38ruoe_HdDswRBCNcxXLO9O2AyiiHDt781mwsJzWeyyahySfwjpq4ZL/exec",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"op\": \"login\",\n  \"password\": \"fairytails22\"\n}",
        "options": {}
      },
      "id": "wf04-login",
      "name": "Apps Script login (get token)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 760]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.telegram.org/file/bot8684875673:AAESXfJ0KxrKjavgwOXLyrY8_VMC4yW9yWA/{{ $('Telegram getFile').item.json.result.file_path }}",
        "options": {
          "response": { "response": { "responseFormat": "file" } }
        }
      },
      "id": "wf04-download",
      "name": "Download PDF binary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 760]
    },
    {
      "parameters": {
        "jsCode": "// Build the op_upload_pdf body.\n//\n// Binary handling note: when n8n stores binary data in 'filesystem' mode,\n// $input.item.binary.<name>.data contains a filesystem reference (e.g. 'filesystem-v2'),\n// NOT the actual base64. We MUST use this.helpers.getBinaryDataBuffer() to get the\n// real bytes; that helper works in both memory and filesystem modes.\n\nconst loginItem = $('Apps Script login (get token)').item;\nconst parseItem = $('Parse text + look up pending').item;\nconst downloadItem = $input.item;\n\nconst token = loginItem.json?.data?.token;\nif (!token) {\n  throw new Error('Could not get auth_token from op_login: ' + JSON.stringify(loginItem.json).slice(0, 200));\n}\n\nconst binaryName = Object.keys(downloadItem.binary ?? {})[0];\nif (!binaryName) throw new Error('No binary on Download node output');\n\n// Read the actual bytes via helper, then base64-encode.\nconst buf = await this.helpers.getBinaryDataBuffer(0, binaryName);\nconst base64Data = buf.toString('base64');\n\n// (Note: pending PDF clearing moved to the post-upload Clear-pending node\n// so failed uploads don't lose the staging.)\n\nreturn [{\n  json: {\n    auth_token: token,\n    profile_id: parseItem.json.profile_id,\n    pdf_blob_b64: 'data:application/pdf;base64,' + base64Data,\n    original_filename: parseItem.json.file_name,\n    chat_id: parseItem.json.chat_id,\n    message_id: parseItem.json.message_id,\n    user_first_name: parseItem.json.user_first_name,\n    pdf_size_bytes: buf.length,\n  },\n}];\n"
      },
      "id": "wf04-build-payload",
      "name": "Build upload_pdf payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 760]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://script.google.com/macros/s/AKfycby5CU8J-xyCn38ruoe_HdDswRBCNcxXLO9O2AyiiHDt781mwsJzWeyyahySfwjpq4ZL/exec",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"op\": \"upload_pdf\",\n  \"auth_token\": \"{{ $json.auth_token }}\",\n  \"profile_id\": \"{{ $json.profile_id }}\",\n  \"pdf_blob_b64\": \"{{ $json.pdf_blob_b64 }}\",\n  \"original_filename\": \"{{ $json.original_filename }}\"\n}",
        "options": { "timeout": 90000 }
      },
      "id": "wf04-upload-pdf",
      "name": "Apps Script op_upload_pdf",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2220, 760]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "id": "upload-ok",
              "leftValue": "={{ $json.ok }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "wf04-upload-result-gate",
      "name": "IF: upload_pdf succeeded?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [2440, 760]
    },
    {
      "parameters": {
        "jsCode": "// Now that op_upload_pdf returned ok:true, clear the pending PDF for this chat.\n// On failure (ok:false branch) we leave it stashed so user can retry by sending PRF-XXX again.\nconst parseItem = $('Parse text + look up pending').item;\nconst chatId = String(parseItem.json.chat_id);\nconst static_ = $getWorkflowStaticData('global');\nif (static_.pendingPdfs && static_.pendingPdfs[chatId]) {\n  delete static_.pendingPdfs[chatId];\n}\nreturn [{ json: { cleared: true, chat_id: parseItem.json.chat_id } }];\n"
      },
      "id": "wf04-clear-pending",
      "name": "Clear pending intake",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2660, 700]
    },
    {
      "parameters": {
        "chatId": "={{ $('Parse text + look up pending').item.json.chat_id }}",
        "text": "=✓ PDF \"{{ $('Parse text + look up pending').item.json.file_name }}\" attached to {{ $('Parse text + look up pending').item.json.profile_id }}.\n\n👉 Tap to start AI extraction (one click — keep the page open ~2 min):\n\nhttps://fairytails123.github.io/groomingbackend/admin/upload.html?reextract=1&pid={{ $('Parse text + look up pending').item.json.profile_id }}\n\nWhen extraction finishes, the profile will be in 'Needs Review' — click Publish to push to the TV.",
        "additionalFields": {
          "reply_to_message_id": "={{ $('Parse text + look up pending').item.json.message_id }}"
        }
      },
      "id": "wf04-success-reply",
      "name": "Telegram: success reply",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [2880, 700],
      "credentials": {
        "telegramApi": { "name": "Telegram groomingbackend" }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $('Parse text + look up pending').item.json.chat_id }}",
        "text": "=⚠️ Apps Script rejected the upload for {{ $('Parse text + look up pending').item.json.profile_id }}.\n\nError: {{ $json.error.code ?? 'UNKNOWN' }} — {{ $json.error.message ?? 'no detail' }}\n\nThe PDF \"{{ $('Parse text + look up pending').item.json.file_name }}\" stays stashed; reply with the profile_id again to retry, or send a fresh PDF if this one is corrupted.",
        "additionalFields": {
          "reply_to_message_id": "={{ $('Parse text + look up pending').item.json.message_id }}"
        }
      },
      "id": "wf04-error-reply",
      "name": "Telegram: upload error reply",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [2660, 880],
      "credentials": {
        "telegramApi": { "name": "Telegram groomingbackend" }
      }
    },

    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "id": "no-pdf-error",
              "leftValue": "={{ $json.error_kind }}",
              "rightValue": "no_pdf",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
